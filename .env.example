# Supabase (create a project at https://supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production site URL for auth (confirmation & password reset emails). Must match Supabase Dashboard → Authentication → URL Configuration (Site URL + Redirect URLs).
# e.g. https://f1-fantasyclub.netlify.app (no trailing slash)
VITE_SITE_URL=https://f1-fantasyclub.netlify.app

# F1 Fantasy backend (FastAPI) – e.g. http://localhost:8000
VITE_API_URL=https://f1-fantasy-backend-5ssv.onrender.com/
